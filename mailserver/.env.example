# Copy to .env and fill in real values. Never commit real secrets.
MONGO_URI=mongodb://localhost:27017
DB_NAME=myemails
# Required outside local development (NODE_ENV=development). Generate with:
#   openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32
# No ADMIN_* vars — admins are created via `pnpm run create-invite-admin`,
# then signing up with the printed invite code.
ALLOWED_DOMAINS=example.com
TRUST_PROXY=0
PORT=4000
SMTP_PORT=25
EMAIL_RETENTION_DAYS=30
